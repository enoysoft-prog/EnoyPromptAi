// ============================================================
// PromptVault — Firestore Security Rules v3 (Complete)
// PASTE INTO: Firebase Console → Firestore → Rules → Publish
// ============================================================
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ──────────────────────────────────────
    function isSignedIn()          { return request.auth != null; }
    function isOwner(uid)          { return isSignedIn() && request.auth.uid == uid; }
    function isAdminUser()         {
      // Admin = any Firebase Auth user signing in from the admin panel
      // For extra security, add your admin UID here:
      // return isSignedIn() && request.auth.uid == "YOUR_ADMIN_UID_HERE";
      return isSignedIn();
    }

    // ── PUBLIC CONTENT ─────────────────────────────────────────
    // Android app + website can read without auth
    match /prompts/{id} {
      allow read:  if true;
      allow write: if isAdminUser();
    }
    match /categories/{id} {
      allow read:  if true;
      allow write: if isAdminUser();
    }
    match /subcategories/{id} {
      allow read:  if true;
      allow write: if isAdminUser();
    }
    match /tools/{id} {
      allow read:  if true;
      allow write: if isAdminUser();
    }
    match /config/{id} {
      allow read:  if true;
      allow write: if isAdminUser();
    }

    // ── USER ACCOUNTS ──────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdminUser();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdminUser();
      allow delete: if isAdminUser();
      allow list:   if isAdminUser();
    }

    // ── COIN TRANSACTIONS (user read own, admin read all) ──────
    match /coin_transactions/{txId} {
      allow read:   if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminUser());
      allow create: if isSignedIn();
      allow update: if isAdminUser();
      allow delete: if isAdminUser();
      allow list:   if isAdminUser();
    }

    // ── PROMPT SUBMISSIONS ─────────────────────────────────────
    match /prompt_submissions/{subId} {
      allow read:   if isSignedIn() && (resource.data.submittedBy == request.auth.uid || isAdminUser());
      allow create: if isSignedIn();
      allow update: if isAdminUser();
      allow delete: if isAdminUser();
      allow list:   if isAdminUser();
    }

    // ── REFERRALS ──────────────────────────────────────────────
    match /referrals/{refId} {
      allow read:   if isAdminUser();
      allow create: if isSignedIn();
      allow update: if isAdminUser();
      allow delete: if isAdminUser();
      allow list:   if isAdminUser();
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
